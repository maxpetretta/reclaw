---
import "@fontsource-variable/inter/standard.css"
import "@fontsource-variable/inter/standard-italic.css"
import "@/styles/global.css"

const title = "Reclaw | Durable memory for OpenClaw"
const description =
  "An append-only event log that captures structured knowledge from every session. Facts, decisions, tasks — extracted automatically, searchable instantly."

const features = [
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: "Event log",
    description:
      "Append-only structured entries — facts, decisions, tasks, questions, and session handoffs. Never mutated, always queryable.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M12 22v-5"/><path d="M9 22h6"/></svg>`,
    title: "Smart extraction",
    description:
      "An LLM reads each transcript and extracts only user-specific knowledge. General information any model could produce is filtered out.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
    title: "Memory snapshot",
    description:
      "A nightly cron rewrites the generated section of MEMORY.md with current interests, active work, open loops, and durable knowledge.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Structured search",
    description:
      "Filter by type, subject, or status. Keyword search via ripgrep. Semantic search over MEMORY.md via the builtin indexer.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44H2.5A2.5 2.5 0 0 1 0 17.5v-13A2.5 2.5 0 0 1 2.5 2z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44h4.54A2.5 2.5 0 0 0 24 17.5v-13A2.5 2.5 0 0 0 21.5 2z"/></svg>`,
    title: "Subject registry",
    description:
      "Organize entries by project, person, system, or topic. Auto-created from extraction, manageable via CLI.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    title: "Import history",
    description:
      "Bring in conversations from ChatGPT, Claude, and Grok. Async background jobs with dedup and resume support.",
  },
]

const nodes = [
  { cx: 85, cy: 78, r: 5, d: 0, color: "coral" },
  { cx: 210, cy: 145, r: 7, d: 0.8, color: "violet" },
  { cx: 350, cy: 85, r: 6, d: 1.5, color: "coral" },
  { cx: 480, cy: 190, r: 8, d: 0.3, color: "violet" },
  { cx: 620, cy: 105, r: 5.5, d: 2.1, color: "coral" },
  { cx: 750, cy: 210, r: 7, d: 1.1, color: "violet" },
  { cx: 890, cy: 130, r: 6, d: 0.6, color: "coral" },
  { cx: 1020, cy: 200, r: 5, d: 1.8, color: "violet" },
  { cx: 1130, cy: 95, r: 6.5, d: 2.4, color: "coral" },
  { cx: 150, cy: 290, r: 6, d: 1.3, color: "violet" },
  { cx: 310, cy: 340, r: 5, d: 0.5, color: "coral" },
  { cx: 500, cy: 380, r: 7.5, d: 1.9, color: "violet" },
  { cx: 680, cy: 350, r: 6, d: 0.2, color: "coral" },
  { cx: 830, cy: 400, r: 5.5, d: 2.6, color: "violet" },
  { cx: 970, cy: 340, r: 7, d: 1.4, color: "coral" },
  { cx: 1100, cy: 380, r: 5, d: 0.9, color: "violet" },
  { cx: 260, cy: 470, r: 6, d: 2, color: "coral" },
  { cx: 440, cy: 520, r: 5, d: 0.7, color: "violet" },
  { cx: 640, cy: 490, r: 7, d: 1.6, color: "coral" },
  { cx: 820, cy: 540, r: 6, d: 2.3, color: "violet" },
  { cx: 1000, cy: 480, r: 5.5, d: 1, color: "coral" },
  { cx: 60, cy: 450, r: 4, d: 1.7, color: "violet" },
  { cx: 1150, cy: 520, r: 4.5, d: 0.4, color: "coral" },
]

const edges: Array<[number, number]> = [
  [0, 1],
  [1, 2],
  [1, 3],
  [2, 4],
  [3, 5],
  [4, 5],
  [4, 6],
  [5, 7],
  [6, 8],
  [7, 8],
  [0, 9],
  [1, 9],
  [9, 10],
  [3, 10],
  [3, 11],
  [10, 11],
  [11, 12],
  [5, 12],
  [12, 13],
  [7, 14],
  [13, 14],
  [14, 15],
  [8, 15],
  [9, 16],
  [10, 16],
  [16, 17],
  [11, 17],
  [17, 18],
  [12, 18],
  [18, 19],
  [13, 19],
  [19, 20],
  [14, 20],
  [15, 20],
  [21, 9],
  [21, 16],
  [20, 22],
  [15, 22],
]

const decayRows = [
  { label: "today", fade: 1, color: "brand", dotOpacity: "", barStops: "from-brand/35 via-brand/15 to-brand/05" },
  {
    label: "3 days",
    fade: 0.85,
    color: "brand/80",
    dotOpacity: "",
    barStops: "from-brand/25 via-brand/10 to-transparent",
  },
  { label: "2 weeks", fade: 0.7, color: "brand/60", dotOpacity: "", barStops: "from-brand/18 to-transparent" },
  { label: "1 month", fade: 0.5, color: "brand/40", dotOpacity: "", barStops: "from-brand/12 to-transparent" },
  { label: "3 months", fade: 0.35, color: "brand/25", dotOpacity: "", barStops: "from-brand/08 to-transparent" },
  { label: "6 months", fade: 0.2, color: "brand/12", dotOpacity: "", barStops: "from-brand/04 to-transparent" },
  { label: "1 year", fade: 0.1, color: "brand/06", dotOpacity: "", barStops: "from-brand/02 to-transparent" },
  { label: "gone", fade: 0.04, color: "brand/03", dotOpacity: "", barStops: "from-brand/01 to-transparent" },
]
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f14" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? "https://reclaw.sh")} />
  </head>

  <body class="bg-background text-foreground antialiased">
    <!-- ════════════════════════════════════════════ HEADER -->
    <header class="sticky top-0 z-50 backdrop-blur-xl bg-background/80 border-b border-border">
      <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between">
        <a href="#top" class="flex items-center gap-2 text-foreground font-semibold text-sm">
          <span>🦞</span>
          <span>Reclaw</span>
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm text-muted-foreground">
          <a href="#how" class="hover:text-foreground transition-colors">How it works</a>
          <a href="#features" class="hover:text-foreground transition-colors">Features</a>
          <a href="#start" class="hover:text-foreground transition-colors">Get started</a>
        </nav>
        <a
          href="https://github.com/maxpetretta/reclaw"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          GitHub &rarr;
        </a>
      </div>
    </header>

    <!-- ════════════════════════════════════════════ HERO -->
    <section id="top" class="hero-section relative overflow-hidden md:mx-5 lg:mx-auto md:max-w-5xl md:mt-6 md:rounded-2xl md:border md:border-border reveal">
      <div class="hero-graph" aria-hidden="true">
        <svg viewBox="0 0 1200 620" preserveAspectRatio="xMidYMid slice" role="presentation" focusable="false">
          <defs>
            <radialGradient id="glow-coral" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.9" />
              <stop offset="100%" stop-color="var(--brand)" stop-opacity="0" />
            </radialGradient>
            <radialGradient id="glow-violet" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#7c3aed" stop-opacity="0.9" />
              <stop offset="100%" stop-color="#7c3aed" stop-opacity="0" />
            </radialGradient>
            <filter id="edge-blur">
              <feGaussianBlur stdDeviation="0.8" />
            </filter>
          </defs>

          <g class="graph-edges">
            {edges.map(([a, b], index) => {
              const sourceNode = nodes[a]
              const targetNode = nodes[b]
              if (!(sourceNode && targetNode)) return null
              return (
                <line
                  x1={sourceNode.cx} y1={sourceNode.cy}
                  x2={targetNode.cx} y2={targetNode.cy}
                  style={`--edge-d: ${(index * 0.4) % 3}s`}
                />
              )
            })}
          </g>

          <g class="graph-halos">
            {nodes.map((node) => (
              <circle
                cx={node.cx} cy={node.cy} r={node.r * 4}
                fill={node.color === "coral" ? "url(#glow-coral)" : "url(#glow-violet)"}
                style={`--d: ${node.d}s`}
                class="halo"
              />
            ))}
          </g>

          <g class="graph-nodes">
            {nodes.map((node) => (
              <circle cx={node.cx} cy={node.cy} r={node.r} class={`node node-${node.color}`} style={`--d: ${node.d}s`} />
            ))}
          </g>
        </svg>
      </div>

      <div class="hero-scanlines" aria-hidden="true"></div>

      <div class="relative z-10 px-6 pt-24 pb-16 md:px-10 md:pt-48 md:pb-24">
        <p class="hero-kicker font-mono text-[8px] sm:text-xs tracking-[0.2em] uppercase text-brand mb-5 inline-flex items-center gap-2 rounded-full border border-brand/40 bg-brand-soft px-3.5 py-1.5 backdrop-blur-sm">
          <span aria-hidden="true">🦞</span>
          Durable memory for OpenClaw
        </p>

        <h1 class="hero-title hero-heading font-extrabold tracking-tighter leading-none text-foreground">
          <span class="whitespace-nowrap">Conversations fade.</span><br />
          <span class="hero-accent whitespace-nowrap">Knowledge compounds.</span>
        </h1>

        <p class="hero-sub mt-8 text-lg md:text-xl text-[#C8CDDF] max-w-xl leading-relaxed">
          An append-only event log that captures structured knowledge from every session &mdash; facts, decisions, tasks, questions &mdash; extracted automatically, searchable instantly.
        </p>

        <div class="hero-actions mt-10 flex flex-wrap gap-3">
          <a
            href="#start"
            class="inline-flex items-center px-5 py-2.5 bg-brand text-white font-semibold text-sm rounded-lg hover:brightness-110 transition-all hover:-translate-y-0.5 active:translate-y-0 shadow-lg shadow-brand/30"
          >
            Get started
          </a>
          <a
            href="https://github.com/maxpetretta/reclaw"
            class="inline-flex items-center px-5 py-2.5 border border-border text-foreground font-semibold text-sm rounded-lg hover:bg-card transition-all hover:-translate-y-0.5 active:translate-y-0 backdrop-blur-sm"
          >
            View on GitHub
          </a>
        </div>
      </div>

      <aside class="hero-marginalia" aria-hidden="true">
        <span class="font-mono text-xs text-violet-400 tracking-wide">append-only</span>
        <span class="text-sm italic text-muted-foreground leading-relaxed border-l-2 border-violet-500/30 pl-2.5"
          >"The log is authoritative. The snapshot is a cache."</span
        >
      </aside>
    </section>

    <main class="max-w-5xl mx-auto px-5">
      <!-- ════════════════════════════════════════════ PROBLEM -->
      <section class="py-20 sm:py-24">
        <div class="reveal max-w-2xl mx-auto text-center">
          <h2 class="text-2xl sm:text-4xl font-bold tracking-tight leading-snug">
            Conversations fade.<br />
            <span class="text-muted-foreground">Knowledge should compound.</span>
          </h2>
          <p class="mt-6 text-muted-foreground text-base sm:text-lg leading-relaxed max-w-lg mx-auto">
            Every session produces decisions, context, and open loops. Without durable memory, your agent starts from zero each time.
          </p>
        </div>

        <div class="reveal mt-14 max-w-2xl mx-auto space-y-2.5">
          {decayRows.map((row, i) => (
            <div class="decay-row" style={`--fade: ${row.fade}; --pulse-delay: ${i * 0.3}s;`}>
              <div class={`decay-dot bg-${row.color} ${i < 7 ? 'decay-pulse' : ''}`}></div>
              <div
                class={`decay-bar flex-1 h-3 rounded-full bg-gradient-to-r ${row.barStops}`}
                style={`--pulse-delay: ${i * 0.3}s;`}
              ></div>
              <span class={`text-xs tabular-nums w-20 text-right ${i === 0 ? 'text-brand/70' : i < 4 ? 'text-brand/50' : 'text-muted-foreground/' + Math.max(5, Math.round(row.fade * 50))}`}>
                {row.label}
              </span>
            </div>
          ))}
        </div>
      </section>

      <!-- ════════════════════════════════════════════ DEMO -->
      <section class="py-20" id="demo">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal">See it in action</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-10 reveal">
          Your conversations become structured memory
        </h2>

        <div class="grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-8 items-center reveal">
          <div class="rounded-xl border border-border bg-card p-5">
            <div class="flex items-center gap-2 text-xs text-muted-foreground font-mono mb-4">
              <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
              Session transcript
            </div>
            <div class="space-y-3">
              <div class="rounded-lg bg-muted px-4 py-3 text-sm text-foreground/90 leading-relaxed">
                We decided to use queue-based retries for webhook delivery instead of synchronous. The cascading failures were too risky.
              </div>
              <div class="rounded-lg bg-brand-soft border border-brand/20 px-4 py-3 text-sm text-foreground/90 leading-relaxed">
                Good call. I'll note that decision. The backfill script for the 47 failed jobs from last week is still pending &mdash; want me to track that as an open task?
              </div>
            </div>
          </div>

          <div class="hidden md:flex items-center self-center">
            <span class="demo-arrow text-brand text-2xl font-bold select-none" aria-hidden="true">&rarr;</span>
          </div>
          <div class="flex md:hidden justify-center -my-2">
            <span class="demo-arrow text-brand text-2xl font-bold select-none" aria-hidden="true">&darr;</span>
          </div>

          <div class="rounded-xl border border-border bg-card p-5">
            <div class="flex items-center gap-2 text-xs text-muted-foreground font-mono mb-4">
              <span class="w-2 h-2 rounded-full bg-brand shrink-0"></span>
              Extracted to log.jsonl
            </div>
            <div class="space-y-2.5 font-mono text-[11px] sm:text-xs leading-relaxed">
              <div class="log-entry log-entry-decision">
                <span class="log-type text-violet-400">decision</span>
                <span class="text-foreground/80">Queue-based retries for webhook delivery</span>
                <span class="text-muted-foreground/50">auth-migration</span>
              </div>
              <div class="log-entry log-entry-task">
                <span class="log-type text-brand">task:open</span>
                <span class="text-foreground/80">Backfill script for 47 failed webhook jobs</span>
                <span class="text-muted-foreground/50">auth-migration</span>
              </div>
              <div class="log-entry log-entry-handoff">
                <span class="log-type text-emerald-400">handoff</span>
                <span class="text-foreground/80">Retry logic done, backfill + canary pending</span>
                <span class="text-muted-foreground/50">&nbsp;</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════════════ HOW IT WORKS -->
      <section class="py-20" id="how">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal">How it works</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-4 reveal">Three steps to <span class="hero-accent">total recall</span></h2>
        <p class="text-muted-foreground leading-relaxed max-w-2xl mb-4 reveal">
          Reclaw replaces OpenClaw's default <code class="font-mono text-xs bg-violet-500/15 text-violet-400 px-1.5 py-0.5 rounded">memory-core</code> with an append-only event log. Sessions produce structured entries. A nightly snapshot keeps MEMORY.md current.
        </p>
        <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground mb-12 reveal">
          <span>session ends</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>extraction hook</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>structured entries in log.jsonl</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>nightly snapshot to MEMORY.md</span>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <article class="reveal step-card">
            <div class="step-number">1</div>
            <div class="step-icon">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 17 10 11 4 5"/>
                <line x1="12" y1="19" x2="20" y2="19"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mt-5">Install</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
              Install the plugin and run init. Reclaw creates the log directory, sets the memory slot, registers the nightly cron, and adds managed blocks to MEMORY.md.
            </p>
          </article>
          <article class="reveal step-card">
            <div class="step-number">2</div>
            <div class="step-icon">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mt-5">Converse</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
              Use OpenClaw normally. When a session ends, the extraction hook reads the transcript and an LLM extracts structured entries &mdash; applying a hard filter for user-specific knowledge only.
            </p>
          </article>
          <article class="reveal step-card">
            <div class="step-number">3</div>
            <div class="step-icon">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/>
                <path d="M2 12h2"/><path d="M20 12h2"/>
                <path d="M12 22v-5"/><path d="M9 22h6"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mt-5">Remember</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
              Facts, decisions, tasks, and open questions accumulate in the log. A nightly cron rewrites your MEMORY.md snapshot. Your agent starts every session with full context.
            </p>
          </article>
        </div>
      </section>

      <!-- ════════════════════════════════════════════ FEATURES -->
      <section class="py-20" id="features">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal">Capabilities</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-10 reveal">Everything the log provides</h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden reveal">
          {features.map((feature) => (
            <div class="bg-background p-6 hover:bg-card transition-colors group">
              <div class="w-9 h-9 rounded-lg bg-brand-soft flex items-center justify-center text-brand mb-4 group-hover:bg-brand/20 transition-colors" set:html={feature.icon} />
              <h3 class="font-bold text-foreground text-sm mb-1.5">{feature.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ════════════════════════════════════════════ INSTALL -->
      <section class="py-20" id="start">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal text-center">Get started</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-6 reveal text-center">
          Two commands. That's it.
        </h2>
        <p class="text-muted-foreground leading-relaxed max-w-2xl mx-auto mb-8 reveal text-center">
          Install the plugin, run init, and your next session will automatically extract structured memory.
        </p>

        <div class="max-w-lg mx-auto reveal">
          <div class="terminal">
            <div class="terminal-bar">
              <div class="flex gap-2">
                <span class="w-3 h-3 rounded-full bg-white/10"></span>
                <span class="w-3 h-3 rounded-full bg-white/10"></span>
                <span class="w-3 h-3 rounded-full bg-white/10"></span>
              </div>
              <div class="flex-1"></div>
              <button
                id="install-copy-btn"
                type="button"
                class="terminal-copy-btn group/copy flex items-center gap-1.5 text-xs text-muted-foreground/40 hover:text-muted-foreground transition-colors cursor-pointer"
                title="Copy commands"
              >
