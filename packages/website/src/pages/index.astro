---
import "@fontsource-variable/inter/standard.css"
import "@fontsource-variable/inter/standard-italic.css"
import "@/styles/global.css"

const title = "Reclaw | Reclaim your AI conversations"
const description =
  "Export your ChatGPT, Claude, and Grok history — normalize to markdown, bootstrap your agent's memory."

const features = [
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: "Event log",
    description:
      "Append-only structured entries — facts, decisions, tasks, questions, and session handoffs. Never mutated, always queryable.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M12 22v-5"/><path d="M9 22h6"/></svg>`,
    title: "Smart extraction",
    description:
      "An LLM reads each transcript and extracts only user-specific knowledge. General information any model could produce is filtered out.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
    title: "Memory snapshot",
    description:
      "A nightly cron rewrites the generated section of MEMORY.md with current interests, active work, open loops, and durable knowledge.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Structured search",
    description:
      "Filter by type, subject, or status. Keyword search via ripgrep. Semantic search over MEMORY.md via the builtin indexer.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44H2.5A2.5 2.5 0 0 1 0 17.5v-13A2.5 2.5 0 0 1 2.5 2z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44h4.54A2.5 2.5 0 0 0 24 17.5v-13A2.5 2.5 0 0 0 21.5 2z"/></svg>`,
    title: "Subject registry",
    description:
      "Organize entries by project, person, system, or topic. Auto-created from extraction, manageable via CLI.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    title: "Import history",
    description:
      "Bring in conversations from ChatGPT, Claude, and Grok. Async background jobs with dedup and resume support.",
  },
]

const nodes = [
  { cx: 85, cy: 78, r: 5, d: 0, color: "coral" },
  { cx: 210, cy: 145, r: 7, d: 0.8, color: "violet" },
  { cx: 350, cy: 85, r: 6, d: 1.5, color: "coral" },
  { cx: 480, cy: 190, r: 8, d: 0.3, color: "violet" },
  { cx: 620, cy: 105, r: 5.5, d: 2.1, color: "coral" },
  { cx: 750, cy: 210, r: 7, d: 1.1, color: "violet" },
  { cx: 890, cy: 130, r: 6, d: 0.6, color: "coral" },
  { cx: 1020, cy: 200, r: 5, d: 1.8, color: "violet" },
  { cx: 1130, cy: 95, r: 6.5, d: 2.4, color: "coral" },
  { cx: 150, cy: 290, r: 6, d: 1.3, color: "violet" },
  { cx: 310, cy: 340, r: 5, d: 0.5, color: "coral" },
  { cx: 500, cy: 380, r: 7.5, d: 1.9, color: "violet" },
  { cx: 680, cy: 350, r: 6, d: 0.2, color: "coral" },
  { cx: 830, cy: 400, r: 5.5, d: 2.6, color: "violet" },
  { cx: 970, cy: 340, r: 7, d: 1.4, color: "coral" },
  { cx: 1100, cy: 380, r: 5, d: 0.9, color: "violet" },
  { cx: 260, cy: 470, r: 6, d: 2, color: "coral" },
  { cx: 440, cy: 520, r: 5, d: 0.7, color: "violet" },
  { cx: 640, cy: 490, r: 7, d: 1.6, color: "coral" },
  { cx: 820, cy: 540, r: 6, d: 2.3, color: "violet" },
  { cx: 1000, cy: 480, r: 5.5, d: 1, color: "coral" },
  { cx: 60, cy: 450, r: 4, d: 1.7, color: "violet" },
  { cx: 1150, cy: 520, r: 4.5, d: 0.4, color: "coral" },
]

const edges: Array<[number, number]> = [
  [0, 1],
  [1, 2],
  [1, 3],
  [2, 4],
  [3, 5],
  [4, 5],
  [4, 6],
  [5, 7],
  [6, 8],
  [7, 8],
  [0, 9],
  [1, 9],
  [9, 10],
  [3, 10],
  [3, 11],
  [10, 11],
  [11, 12],
  [5, 12],
  [12, 13],
  [7, 14],
  [13, 14],
  [14, 15],
  [8, 15],
  [9, 16],
  [10, 16],
  [16, 17],
  [11, 17],
  [17, 18],
  [12, 18],
  [18, 19],
  [13, 19],
  [19, 20],
  [14, 20],
  [15, 20],
  [21, 9],
  [21, 16],
  [20, 22],
  [15, 22],
]

const decayRows = [
  { label: "today", fade: 1, color: "brand", dotOpacity: "", barStops: "from-brand/35 via-brand/15 to-brand/05" },
  {
    label: "3 days",
    fade: 0.85,
    color: "brand/80",
    dotOpacity: "",
    barStops: "from-brand/25 via-brand/10 to-transparent",
  },
  { label: "2 weeks", fade: 0.7, color: "brand/60", dotOpacity: "", barStops: "from-brand/18 to-transparent" },
  { label: "1 month", fade: 0.5, color: "brand/40", dotOpacity: "", barStops: "from-brand/12 to-transparent" },
  { label: "3 months", fade: 0.35, color: "brand/25", dotOpacity: "", barStops: "from-brand/08 to-transparent" },
  { label: "6 months", fade: 0.2, color: "brand/12", dotOpacity: "", barStops: "from-brand/04 to-transparent" },
  { label: "1 year", fade: 0.1, color: "brand/06", dotOpacity: "", barStops: "from-brand/02 to-transparent" },
  { label: "gone", fade: 0.04, color: "brand/03", dotOpacity: "", barStops: "from-brand/01 to-transparent" },
]
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f14" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? "https://reclaw.sh")} />
  </head>

  <body class="bg-background text-foreground antialiased">
    <!-- ════════════════════════════════════════════ STICKY GITHUB NAV -->
    <nav class="fixed top-0 right-0 z-50 p-4 sm:p-5">
      <a
        href="https://github.com/maxpetretta/reclaw"
        target="_blank"
        rel="noopener"
        class="github-btn group inline-flex items-center gap-2 rounded-full border border-border bg-background/70 backdrop-blur-lg px-4 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:border-amber-500/40 transition-all"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        GitHub
      </a>
    </nav>

    <!-- ════════════════════════════════════════════ HERO -->
    <section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden px-6">
      <!-- Amber orb -->
      <div class="amber-orb" aria-hidden="true"></div>
      <!-- Strata lines -->
      <div class="strata" aria-hidden="true">
        <div class="strata-line" style="--y: 18%; --w: 60%; --delay: 0s;"></div>
        <div class="strata-line" style="--y: 34%; --w: 45%; --delay: 0.4s;"></div>
        <div class="strata-line" style="--y: 52%; --w: 70%; --delay: 0.8s;"></div>
        <div class="strata-line" style="--y: 68%; --w: 38%; --delay: 1.2s;"></div>
        <div class="strata-line" style="--y: 82%; --w: 55%; --delay: 1.6s;"></div>
      </div>

      <div class="relative z-10 max-w-3xl text-center">
        <p class="hero-kicker mb-5 text-sm font-semibold tracking-[0.2em] uppercase text-amber-400/90">
          Durable OpenClaw memory
        </p>
        <h1 class="hero-title text-5xl sm:text-6xl md:text-7xl font-extrabold leading-[1.08] tracking-tight">
          Your best ideas are
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-orange-400 to-red-400">buried in old chats</span>
        </h1>
        <p class="hero-sub mt-7 text-lg sm:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed">
          Every conversation produces knowledge. Reclaw makes sure none of it gets lost &mdash; extracting facts, decisions, and tasks into a searchable event log that compounds over time.
        </p>
        <div class="hero-actions mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <div class="group relative">
            <div class="absolute -inset-1 rounded-xl bg-gradient-to-r from-amber-500/40 to-orange-600/40 blur-lg opacity-60 group-hover:opacity-100 transition-opacity"></div>
            <a
              href="#start"
              class="relative inline-flex items-center gap-2.5 rounded-lg bg-gradient-to-b from-amber-500 to-orange-600 px-7 py-3.5 text-sm font-bold text-white shadow-lg shadow-orange-600/25 hover:shadow-orange-500/40 transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
              Get started
            </a>
          </div>
          <button
            id="hero-copy-btn"
            type="button"
            class="copy-pill inline-flex items-center gap-2.5 rounded-lg border border-border px-6 py-3.5 text-sm font-medium text-muted-foreground hover:text-foreground hover:border-amber-500/40 transition-colors cursor-pointer"
          >
            <code class="hero-copy-text font-mono text-[13px] inline-block w-[5.2rem] text-center">npx reclaw</code>
            <svg class="copy-icon w-3.5 h-3.5 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="check-icon w-3.5 h-3.5 text-green-400 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-muted-foreground/50">
        <span class="text-[11px] tracking-widest uppercase">Scroll</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </div>
    </section>

    <!-- ════════════════════════════════════════════ THE PROBLEM -->
    <section class="relative py-20 sm:py-24 px-6">
      <div class="reveal max-w-2xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight leading-snug">
          Thousands of conversations.<br/>
          <span class="text-muted-foreground">Zero lasting memory.</span>
        </h2>
        <p class="mt-6 text-muted-foreground text-base sm:text-lg leading-relaxed max-w-lg mx-auto">
          You&rsquo;ve spent hundreds of hours talking to AI — debugging, brainstorming, making decisions. All of it sits in silo&rsquo;d apps, decaying. Unsearchable. Forgotten.
        </p>
      </div>

      <!-- Decay visualization -->
      <div class="reveal mt-14 max-w-2xl mx-auto space-y-2.5">
        <div class="decay-row" style="--fade: 1; --pulse-delay: 0s;">
          <div class="decay-dot bg-amber-400 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/35 via-amber-400/15 to-amber-400/05" style="--pulse-delay: 0s;"></div>
          <span class="text-xs text-amber-400/70 tabular-nums w-20 text-right">today</span>
        </div>
        <div class="decay-row" style="--fade: 0.85; --pulse-delay: 0.3s;">
          <div class="decay-dot bg-amber-400/80 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/25 via-amber-400/10 to-transparent" style="--pulse-delay: 0.3s;"></div>
          <span class="text-xs text-amber-400/50 tabular-nums w-20 text-right">3 days</span>
        </div>
        <div class="decay-row" style="--fade: 0.7; --pulse-delay: 0.6s;">
          <div class="decay-dot bg-amber-400/60 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/18 to-transparent" style="--pulse-delay: 0.6s;"></div>
          <span class="text-xs text-muted-foreground/50 tabular-nums w-20 text-right">2 weeks</span>
        </div>
        <div class="decay-row" style="--fade: 0.5; --pulse-delay: 0.9s;">
          <div class="decay-dot bg-amber-400/40 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/12 to-transparent" style="--pulse-delay: 0.9s;"></div>
          <span class="text-xs text-muted-foreground/40 tabular-nums w-20 text-right">1 month</span>
        </div>
        <div class="decay-row" style="--fade: 0.35; --pulse-delay: 1.2s;">
          <div class="decay-dot bg-amber-400/25 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/08 to-transparent" style="--pulse-delay: 1.2s;"></div>
          <span class="text-xs text-muted-foreground/30 tabular-nums w-20 text-right">3 months</span>
        </div>
        <div class="decay-row" style="--fade: 0.2; --pulse-delay: 1.5s;">
          <div class="decay-dot bg-amber-400/12 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/04 to-transparent" style="--pulse-delay: 1.5s;"></div>
          <span class="text-xs text-muted-foreground/20 tabular-nums w-20 text-right">6 months</span>
        </div>
        <div class="decay-row" style="--fade: 0.1; --pulse-delay: 1.8s;">
          <div class="decay-dot bg-amber-400/06 decay-pulse"></div>
          <div class="decay-bar flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/02 to-transparent" style="--pulse-delay: 1.8s;"></div>
          <span class="text-xs text-muted-foreground/10 tabular-nums w-20 text-right">1 year</span>
        </div>
        <div class="decay-row" style="--fade: 0.04; --pulse-delay: 2.1s;">
          <div class="decay-dot bg-amber-400/03"></div>
          <div class="flex-1 h-3 rounded-full bg-gradient-to-r from-amber-400/01 to-transparent"></div>
          <span class="text-xs text-muted-foreground/05 tabular-nums w-20 text-right">gone</span>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════ NEW SITE CONTENT -->
    <main class="max-w-5xl mx-auto px-5">
      <!-- ════════════════════════════════════════════ DEMO -->
      <section class="py-20" id="demo">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal">See it in action</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-10 reveal">
          Your conversations become structured memory
        </h2>

        <div class="grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-8 items-center reveal">
          <div class="rounded-xl border border-border bg-card p-5">
            <div class="flex items-center gap-2 text-xs text-muted-foreground font-mono mb-4">
              <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
              Session transcript
            </div>
            <div class="space-y-3">
              <div class="rounded-lg bg-muted px-4 py-3 text-sm text-foreground/90 leading-relaxed">
                We decided to use queue-based retries for webhook delivery instead of synchronous. The cascading failures were too risky.
              </div>
              <div class="rounded-lg bg-brand-soft border border-brand/20 px-4 py-3 text-sm text-foreground/90 leading-relaxed">
                Good call. I'll note that decision. The backfill script for the 47 failed jobs from last week is still pending &mdash; want me to track that as an open task?
              </div>
            </div>
          </div>

          <div class="hidden md:flex items-center self-center">
            <span class="demo-arrow text-brand text-2xl font-bold select-none" aria-hidden="true">&rarr;</span>
          </div>
          <div class="flex md:hidden justify-center -my-2">
            <span class="demo-arrow text-brand text-2xl font-bold select-none" aria-hidden="true">&darr;</span>
          </div>

          <div class="rounded-xl border border-border bg-card p-5">
            <div class="flex items-center gap-2 text-xs text-muted-foreground font-mono mb-4">
              <span class="w-2 h-2 rounded-full bg-brand shrink-0"></span>
              Extracted to log.jsonl
            </div>
            <div class="space-y-2.5 font-mono text-[11px] sm:text-xs leading-relaxed">
              <div class="log-entry log-entry-decision">
                <span class="log-type text-violet-400">decision</span>
                <span class="text-foreground/80">Queue-based retries for webhook delivery</span>
                <span class="text-muted-foreground/50">auth-migration</span>
              </div>
              <div class="log-entry log-entry-task">
                <span class="log-type text-brand">task:open</span>
                <span class="text-foreground/80">Backfill script for 47 failed webhook jobs</span>
                <span class="text-muted-foreground/50">auth-migration</span>
              </div>
              <div class="log-entry log-entry-handoff">
                <span class="log-type text-emerald-400">handoff</span>
                <span class="text-foreground/80">Retry logic done, backfill + canary pending</span>
                <span class="text-muted-foreground/50">&nbsp;</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════════════ HOW IT WORKS -->
      <section class="py-20" id="how">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-brand mb-4 reveal">How it works</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-4 reveal">Three steps to <span class="hero-accent">total recall</span></h2>
        <p class="text-muted-foreground leading-relaxed max-w-2xl mb-4 reveal">
          Reclaw replaces OpenClaw's default <code class="font-mono text-xs bg-violet-500/15 text-violet-400 px-1.5 py-0.5 rounded">memory-core</code> with an append-only event log. Sessions produce structured entries. A nightly snapshot keeps MEMORY.md current.
        </p>
        <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground mb-12 reveal">
          <span>session ends</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>extraction hook</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>structured entries in log.jsonl</span>
          <span class="text-brand font-bold">&rarr;</span>
          <span>nightly snapshot to MEMORY.md</span>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <article class="reveal step-card">
            <div class="step-number">1</div>
            <div class="step-icon">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 17 10 11 4 5"/>
                <line x1="12" y1="19" x2="20" y2="19"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mt-5">Install</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
              Install the plugin and run init. Reclaw creates the log directory, sets the memory slot, registers the nightly cron, and adds managed blocks to MEMORY.md.
            </p>
          </article>
          <article class="reveal step-card">
            <div class="step-number">2</div>
            <div class="step-icon">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mt-5">Converse</h3>
