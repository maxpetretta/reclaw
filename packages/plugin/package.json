{
  "name": "reclaw",
  "version": "3.0.0",
  "description": "Durable append-only event log memory system for OpenClaw",
  "license": "MIT",
  "repository": "https://github.com/maxpetretta/reclaw",
  "homepage": "https://reclaw.sh",
  "keywords": [
    "openclaw",
    "memory",
    "plugin",
    "event-log",
